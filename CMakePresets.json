{
  "version": 4,
  "configurePresets": [
    {
      "name": "Development",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TEST": "ON",
        "AUTO_RUN_TEST": "ON"
      }
    },
    {
      "name": "Release",
      "inherits": "Development",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "AUTO_RUN_TEST": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Development",
      "configurePreset": "Development"
    },
    {
      "name": "Release",
      "configurePreset": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "Development",
      "configurePreset": "Development",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "Release",
      "configurePreset": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}